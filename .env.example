# Supabase Configuration
# Copy values dari Supabase Dashboard > Settings > API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: hanya untuk menjalankan scripts/run-migrations.js dari mesin lokal.
# Jangan pernah expose key ini ke frontend atau commit .env asli.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Backend-only WhatsApp notifications via Fonnte.
# Do not prefix this with VITE_.
FONNTE_TOKEN=YOUR_TOKEN_HERE
FONNTE_TARGETS=6287884820507,6285659085578
VITE_BACKEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173
ENABLE_LEGACY_MYSQL_ROUTES=false
INTEGRATION_RATE_LIMIT_MAX=10
INTEGRATION_RATE_LIMIT_WINDOW_MS=60000

# Runtime stabilization defaults.
# Keep this false in production until first-click freeze / Aw Snap is fully cleared.
VITE_ALLOW_UNSTABLE_RUNTIME=false
VITE_DISABLE_REALTIME=true
VITE_DISABLE_PRESENCE=true
VITE_BACKGROUND_PRELOAD=false
VITE_MINIMAL_DATA_PROVIDER=true
VITE_DISABLE_REPORTS=true
